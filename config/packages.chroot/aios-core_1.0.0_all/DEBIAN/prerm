#!/bin/bash
set -e

# AIOS Core Pre-Removal Script

case "$1" in
    remove|upgrade|deconfigure)
        echo "Stopping AIOS services..."
        
        # Stop all AIOS services
        systemctl stop aios-agent.service 2>/dev/null || true
        systemctl stop aios-browser.service 2>/dev/null || true
        systemctl stop aios-scheduler.service 2>/dev/null || true
        
        # Disable services on removal (not upgrade)
        if [ "$1" = "remove" ]; then
            systemctl disable aios-agent.service 2>/dev/null || true
            systemctl disable aios-browser.service 2>/dev/null || true
            systemctl disable aios-scheduler.service 2>/dev/null || true
        fi
        ;;
        
    failed-upgrade)
        ;;
        
    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0

# Made with Bob
