# LLM selection options (Koii-like user choice)
# Priority:
# 1) KOII_LLM_MODEL (explicit model)
# 2) KOII_LLM_PROFILE
# 3) KOII_LLM_CAPABILITY
# 4) llm.selection.default_model from YAML
KOII_LLM_PROFILE=offline
KOII_LLM_CAPABILITY=
KOII_LLM_MODEL=

# Provider credentials (set these to use real APIs instead of mock)
OPENAI_API_KEY=sk-proj-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
KOII_VLLM_ENDPOINT=http://localhost:8000

# 2FA (TOTP) settings
KOII_2FA_ENABLED=
KOII_2FA_SECRET=

# Messaging integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT_NUMBER=
CODING_WORKSPACE_PATH=.

# Transport & Infrastructure
KOII_TRANSPORT_TYPE=inmemory
KOII_NATS_URL=nats://localhost:4222

# Browser
KOII_BROWSER_BACKEND=playwright
KOII_BROWSER_HEADLESS=true
KOII_BROWSER_SCREENSHOT_DIR=./data/screenshots
KOII_BROWSER_MIN_URL=http://127.0.0.1:43210
KOII_BROWSER_AGENT_TOKEN=your-secure-token
KOII_BROWSER_LAUNCH_CMD=npx electron .

# Web UI
KOII_WEB_PORT=8000
KOII_WEB_HOST=127.0.0.1
