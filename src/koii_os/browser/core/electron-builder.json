{
  "appId": "com.koii.minbrowser",
  "productName": "Min",
  "directories": {
    "buildResources": "icons",
    "output": "dist/app"
  },
  "win": {
    "target": ["portable"],
    "certificateFile": null,
    "certificatePassword": null
  },
  "files": [
    "**/*",
    "!dist/app/**",
    "!node_modules/electron",
    "!.git",
    "!scripts/",
    "!localization/",
    "!**/{.DS_Store,.git,.hg,.svn}",
    "!**/*.map",
    "!**/*.md"
  ]
}
