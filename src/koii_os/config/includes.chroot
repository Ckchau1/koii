inject_aios_payload() {
    echo "=== Injecting AIOS Payload ==="
    mkdir -p config/includes.chroot/opt/aios
    rsync -a --exclude='.git' --exclude='.venv' --exclude='build' --exclude='data' \
        "$ROOT_DIR/" "config/includes.chroot/opt/aios/" 2>/dev/null || true
    echo "Basic AIOS payload injected."
}

build_iso() {
    echo "=== Starting ISO build (this may take 40-90 minutes) ==="
    sudo lb build
}

finalize() {
    if [[ -f live-image-amd64.hybrid.iso ]]; then
        mv live-image-amd64.hybrid.iso "$OUTPUT_ISO"
        echo "=========================================="
        echo "✅ BUILD SUCCESSFUL!"
        echo "ISO saved to: $OUTPUT_ISO"
        du -h "$OUTPUT_ISO"
        echo "=========================================="
    else
        echo "❌ Build failed - ISO not found"
    fi
}
#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="/opt/aios/.env"
EXAMPLE_FILE="/opt/aios/.env.example"

mkdir -p /opt/aios
if [[ -f "$EXAMPLE_FILE" && ! -f "$ENV_FILE" ]]; then
  cp "$EXAMPLE_FILE" "$ENV_FILE"
fi

if [[ ! -f "$ENV_FILE" ]]; then
  touch "$ENV_FILE"
fi

set_kv() {
  local key="$1"
  local val="$2"
  if grep -q "^${key}=" "$ENV_FILE"; then
    sed -i "s|^${key}=.*|${key}=${val}|" "$ENV_FILE"
  else
    echo "${key}=${val}" >> "$ENV_FILE"
  fi
}

unset_kv() {
  local key="$1"
  if grep -q "^${key}=" "$ENV_FILE"; then
    sed -i "s|^${key}=.*|${key}=|" "$ENV_FILE"
  fi
}

prompt_value() {
  local title="$1"
  local prompt="$2"
  local secret="${3:-false}"
  local value=""

  if command -v whiptail >/dev/null 2>&1; then
    if [[ "$secret" == "true" ]]; then
      value=$(whiptail --title "$title" --passwordbox "$prompt" 12 72 3>&1 1>&2 2>&3) || true
    else
      value=$(whiptail --title "$title" --inputbox "$prompt" 12 72 3>&1 1>&2 2>&3) || true
    fi
  else
    if [[ "$secret" == "true" ]]; then
      read -r -s -p "$prompt: " value
      echo
    else
      read -r -p "$prompt: " value
    fi
  fi

  # If this is a confirmation prompt like "(y/n)", and user answered yes,
  # require 2FA verification when enabled in the ENV file.
  if [[ "$prompt" == *"(y/n)"* ]]; then
    if [[ "${value,,}" == "y" || "${value,,}" == "yes" ]]; then
      if [[ -f "/opt/aios/aios-2fa.py" && -f "$ENV_FILE" ]]; then
        local secret_val
        secret_val=$(grep -m1 '^KOII_2FA_SECRET=' "$ENV_FILE" | cut -d'=' -f2- || true)
        local enabled_val
        enabled_val=$(grep -m1 '^KOII_2FA_ENABLED=' "$ENV_FILE" | cut -d'=' -f2- || true)
        if [[ "$enabled_val" == "1" && -n "$secret_val" ]]; then
          local code
          code=$(prompt_value "2FA Verify" "Enter your 2FA code" true)
          if ! python3 /opt/aios/aios-2fa.py verify "$secret_val" "$code" >/dev/null 2>&1; then
            show_message "2FA verification failed. Action cancelled."
            value="n"
          fi
        fi
      fi
    fi
  fi

  echo "$value"
}

validate_http() {
  local url="$1"
  shift
  local http_code=""
  http_code=$(curl -sS -o /dev/null -w "%{http_code}" --connect-timeout 5 --max-time 15 "$@" "$url" || true)
  [[ "$http_code" == "200" ]]
}

validate_openai() {
  local api_key="$1"
  validate_http "https://api.openai.com/v1/models" -H "Authorization: Bearer ${api_key}"
}

validate_anthropic() {
  local api_key="$1"
  validate_http "https://api.anthropic.com/v1/models" -H "x-api-key: ${api_key}" -H "anthropic-version: 2023-06-01"
}

validate_vllm() {
  local endpoint="$1"
  validate_http "${endpoint%/}/v1/models"
}

show_message() {
  local message="$1"
  if command -v whiptail >/dev/null 2>&1; then
    whiptail --title "AIOS LLM Setup" --msgbox "$message" 12 72
  else
    echo "$message"
  fi
}

configure_provider() {
  local profile="$1"
  case "$profile" in
    fast)
      local openai_key=""
      openai_key="$(prompt_value "OpenAI Setup" "Enter your OpenAI API key" true)"
      if [[ -z "$openai_key" ]]; then
        show_message "No OpenAI API key provided. Falling back to offline profile."
        echo "offline"
        return
      fi
      if validate_openai "$openai_key"; then
        set_kv "OPENAI_API_KEY" "$openai_key"
        unset_kv "ANTHROPIC_API_KEY"
        show_message "OpenAI connectivity verified."
        echo "fast"
        return
      fi
      show_message "OpenAI API key validation failed. Falling back to offline profile."
      echo "offline"
      ;;
    quality)
      local anthropic_key=""
      anthropic_key="$(prompt_value "Anthropic Setup" "Enter your Anthropic API key" true)"
      if [[ -z "$anthropic_key" ]]; then
        show_message "No Anthropic API key provided. Falling back to offline profile."
        echo "offline"
        return
      fi
      if validate_anthropic "$anthropic_key"; then
        set_kv "ANTHROPIC_API_KEY" "$anthropic_key"
        unset_kv "OPENAI_API_KEY"
        show_message "Anthropic connectivity verified."
        echo "quality"
        return
      fi
      show_message "Anthropic API key validation failed. Falling back to offline profile."
      echo "offline"
      ;;
    local)
      local vllm_endpoint=""
      vllm_endpoint="$(prompt_value "vLLM Setup" "Enter your local vLLM endpoint" false)"
      if [[ -z "$vllm_endpoint" ]]; then
        vllm_endpoint="http://localhost:8000"
      fi
      if validate_vllm "$vllm_endpoint"; then
        set_kv "KOII_VLLM_ENDPOINT" "$vllm_endpoint"
        show_message "vLLM endpoint connectivity verified."
        echo "local"
        return
      fi
      show_message "vLLM endpoint validation failed. Falling back to offline profile."
      echo "offline"
      ;;
    *)
      unset_kv "OPENAI_API_KEY"
      unset_kv "ANTHROPIC_API_KEY"
      echo "offline"
      ;;
  esac
}

choose_profile_interactive() {
  local choice=""
  if command -v whiptail >/dev/null 2>&1; then
    choice=$(whiptail --title "AIOS LLM Setup" --menu "Choose default LLM profile" 16 70 6 \
      "offline" "Use mock/local-safe default" \
      "fast" "Route to fast cloud model (OpenAI route)" \
      "quality" "Route to higher-quality cloud model (Anthropic route)" \
      "local" "Route to local vLLM endpoint" 3>&1 1>&2 2>&3) || true
  else
    echo "Select default LLM profile:"
    echo "1) offline"
    echo "2) fast"
    echo "3) quality"
    echo "4) local"
    read -r -p "Enter choice [1-4] (default 1): " n
    case "${n:-1}" in
      2) choice="fast" ;;
      3) choice="quality" ;;
      4) choice="local" ;;
      *) choice="offline" ;;
    esac
  fi

  if [[ -z "${choice}" ]]; then
    choice="offline"
  fi
  echo "$choice"
}

if [[ -t 0 || -t 1 ]]; then
  profile="$(choose_profile_interactive)"
else
  profile="offline"
fi

profile="$(configure_provider "$profile")"
set_kv "KOII_LLM_PROFILE" "$profile"
set_kv "KOII_LLM_MODEL" ""
set_kv "KOII_LLM_CAPABILITY" ""

# Offer 2FA TOTP binding
if command -v python3 >/dev/null 2>&1 && [[ -f /opt/aios/aios-2fa.py ]]; then
  enable_2fa="$(prompt_value "2FA Setup" "Enable TOTP 2FA now? (y/n)" false)"
  if [[ "$enable_2fa" == "y" || "$enable_2fa" == "Y" ]]; then
    secret_and_uri="$(python3 /opt/aios/aios-2fa.py generate 2>/dev/null || true)"
    secret="$(echo "$secret_and_uri" | sed -n '1p')"
    uri="$(echo "$secret_and_uri" | sed -n '2p')"
    if [[ -n "$uri" ]]; then
      show_message "Scan this URI with your authenticator app: $uri"
    fi
    code="$(prompt_value "2FA Verify" "Enter the current code from your authenticator" false)"
    if python3 /opt/aios/aios-2fa.py verify "$secret" "$code" >/dev/null 2>&1; then
      set_kv "KOII_2FA_SECRET" "$secret"
      set_kv "KOII_2FA_ENABLED" "1"
      show_message "2FA enabled and verified."
    else
      show_message "2FA verification failed; 2FA not enabled."
    fi
  fi
fi

echo "Configured KOII_LLM_PROFILE=$profile"
EOF
  chmod +x "$EDIT_DIR/usr/local/bin/aios-llm-wizard"
  chmod +x "$EDIT_DIR/opt/aios/aios-settings.py"

  cat > "$EDIT_DIR/usr/local/bin/aios-settings" << 'EOF'
#!/usr/bin/env bash
set -euo pipefail

if command -v pkexec >/dev/null 2>&1; then
  exec pkexec env DISPLAY="$DISPLAY" XAUTHORITY="$XAUTHORITY" /opt/aios/aios-settings.py
else
  exec /opt/aios/aios-settings.py
fi
EOF
  chmod +x "$EDIT_DIR/usr/local/bin/aios-settings"

  cp "$ROOT_DIR/scripts/koii" "$EDIT_DIR/usr/local/bin/koii"
  chmod +x "$EDIT_DIR/usr/local/bin/koii"

  mkdir -p "$EDIT_DIR/usr/share/backgrounds"
  cp "$ROOT_DIR/src/wallpaper/koii.jpg" "$EDIT_DIR/usr/share/backgrounds/koii.jpg"

  mkdir -p "$EDIT_DIR/etc/dconf/db/local.d"
  cat > "$EDIT_DIR/etc/dconf/db/local.d/00-aios-background" << 'EOF'
[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/koii.jpg'
picture-options='zoom'
EOF

  mkdir -p "$EDIT_DIR/etc/dconf/profile"
  cat > "$EDIT_DIR/etc/dconf/profile/user" << 'EOF'
user-db:user
system-db:local
EOF

  mkdir -p "$EDIT_DIR/usr/share/applications"
  cat > "$EDIT_DIR/usr/share/applications/aios-settings.desktop" << 'EOF'
[Desktop Entry]
Name=AIOS Settings
Comment=Configure AIOS LLM API URL, keys, and model selection
Exec=/usr/local/bin/aios-settings
TryExec=/usr/local/bin/aios-settings
Icon=applications-system
Terminal=false
Type=Application
Categories=Settings;Utility;System;
NoDisplay=false
EOF

  cat > "$EDIT_DIR/usr/local/bin/aios-settings-first-run" << 'EOF'
#!/usr/bin/env bash
set -euo pipefail
marker="${XDG_CONFIG_HOME:-$HOME/.config}/aios-settings-first-run.done"
if [[ -f "$marker" ]]; then
  exit 0
fi
mkdir -p "$(dirname "$marker")"
if [[ -n "${DISPLAY:-}" && -n "${XAUTHORITY:-}" ]]; then
  env DISPLAY="$DISPLAY" XAUTHORITY="$XAUTHORITY" /usr/local/bin/aios-settings
else
  /usr/local/bin/aios-settings
fi
touch "$marker"
EOF
  chmod +x "$EDIT_DIR/usr/local/bin/aios-settings-first-run"

  mkdir -p "$EDIT_DIR/etc/xdg/autostart"
  cat > "$EDIT_DIR/etc/xdg/autostart/aios-settings-first-run.desktop" << 'EOF'
[Desktop Entry]
Type=Application
Name=AIOS First Run Setup
Comment=Open AIOS Settings on first login after installation
Exec=/usr/local/bin/aios-settings-first-run
Icon=applications-system
Terminal=false
NoDisplay=false
OnlyShowIn=GNOME;Unity;XFCE;KDE;
X-GNOME-Autostart-enabled=true
Hidden=false
EOF

  cat > "$EDIT_DIR/usr/local/bin/aios-bootstrap" << 'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ -f /var/lib/aios-bootstrap.done ]]; then
  exit 0
fi

export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y python3 python3-pip python3-gi python3-gi-cairo gir1.2-gtk-3.0 docker.io docker-compose-plugin whiptail curl
pip3 install pyotp || true

apt-get update
pip3 install pyotp || true

apt-get update

mkdir -p /opt/aios/data
cd /opt/aios

if [[ -f .env.example && ! -f .env ]]; then
  cp .env.example .env
fi

/usr/local/bin/aios-llm-wizard || true

docker compose up -d || true

if command -v dconf >/dev/null 2>&1; then
  dconf update || true
fi

touch /var/lib/aios-bootstrap.done
systemctl disable aios-bootstrap.service || true
EOF
  chmod +x "$EDIT_DIR/usr/local/bin/aios-bootstrap"

  cat > "$EDIT_DIR/etc/systemd/system/aios-bootstrap.service" << 'EOF'
[Unit]
Description=AIOS Bootstrap Service
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/aios-bootstrap
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

  mkdir -p "$EDIT_DIR/etc/systemd/system/multi-user.target.wants"
  ln -sf /etc/systemd/system/aios-bootstrap.service "$EDIT_DIR/etc/systemd/system/multi-user.target.wants/aios-bootstrap.service"
}